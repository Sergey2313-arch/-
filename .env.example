# ReviMarket environment variables example
# ВАЖНО: это только пример. Настоящие секреты НЕ добавлять в GitHub.

ASPNETCORE_ENVIRONMENT=Development

# Database
REVIMARKET_DB_CONNECTION=Server=localhost;Database=ReviMarketDb;Trusted_Connection=True;TrustServerCertificate=True;

# Auth / JWT
REVIMARKET_JWT_ISSUER=ReviMarket
REVIMARKET_JWT_AUDIENCE=ReviMarketUsers
REVIMARKET_JWT_SECRET=change-this-secret-locally

# Payment provider test keys
PAYMENT_PROVIDER=TestMode
PAYMENT_SHOP_ID=test_shop_id
PAYMENT_SECRET_KEY=test_secret_key
PAYMENT_WEBHOOK_SECRET=test_webhook_secret

# Upload settings
UPLOAD_MAX_MB=25
UPLOAD_ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.webp,.pdf

# Mail settings
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=test@example.com
SMTP_PASSWORD=change-this-password-locally
