@model PaymentInvoice
@{
    ViewData["Title"] = "Оплата счёта";
}

<section class="auth-card neon-card payment-checkout">
    <p class="eyebrow">payment checkout</p>
    <h1>Счёт #@Model.Id</h1>
    <p>Demo-режим: карта не списывается. Проверяется сценарий оплаты, зачисления на баланс и истории операций.</p>

    <div class="detail-price-box">
        <span>Сумма счёта</span>
        <b>@Model.Amount.ToString("N0") ₽</b>
    </div>

    <div class="detail-info-list">
        <div><span>Провайдер</span><b>@Model.Provider</b></div>
        <div><span>Статус</span><b>@Model.Status</b></div>
        <div><span>ID платежа</span><b>@Model.ProviderPaymentId</b></div>
    </div>

    @if (Model.Status == PaymentStatuses.Pending)
    {
        <form asp-action="ConfirmDemo" method="post" class="form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <button class="btn btn-primary" type="submit">Симулировать успешную оплату</button>
        </form>
    }
    else
    {
        <a class="btn btn-primary" href="/Wallet">Вернуться в кошелёк</a>
    }
</section>

<section class="section-block neon-card">
    <p class="eyebrow">real provider later</p>
    <h2>Под реальную платёжку</h2>
    <p>Позже этот экран заменится переходом к платёжному провайдеру. После webhook баланс будет пополняться автоматически.</p>
</section>
