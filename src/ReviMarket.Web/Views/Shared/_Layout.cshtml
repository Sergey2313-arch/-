@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@{
    var layoutUser = SignInManager.IsSignedIn(User) ? await UserManager.GetUserAsync(User) : null;
    var layoutRole = layoutUser?.AccountType;
    var canOpenPanel = User.IsInRole(UserRoles.Admin)
        || User.IsInRole(UserRoles.Manager)
        || User.IsInRole(UserRoles.Owner)
        || User.IsInRole(UserRoles.CoOwner)
        || User.IsInRole(UserRoles.Moderator)
        || User.IsInRole(UserRoles.Lawyer)
        || User.IsInRole(UserRoles.SupportAgent)
        || layoutRole == UserRoles.Admin
        || layoutRole == UserRoles.Manager
        || layoutRole == UserRoles.Owner
        || layoutRole == UserRoles.CoOwner
        || layoutRole == UserRoles.Moderator
        || layoutRole == UserRoles.Lawyer
        || layoutRole == UserRoles.SupportAgent;
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ReviMarket</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/product-photos.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-panel.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/footer-legal.css" asp-append-version="true" />
</head>
<body>
    <div class="bg-grid"></div>
    <header class="topbar">
        <a class="brand" href="/">
            <span class="brand-icon">R</span>
            <span><b>ReviMarket</b><small>работа • заказы • вакансии</small></span>
        </a>
        <nav class="nav">
            <a href="/Orders">Работа</a>
            <a href="/Board">Вакансии</a>
            <a href="/Creators">Исполнители</a>
            @if (SignInManager.IsSignedIn(User))
            {
                <a href="/Profile">Профиль</a>
                @if (canOpenPanel)
                {
                    <a href="/admin.html">Панель</a>
                }
            }
        </nav>
        <div class="auth">
            @if (SignInManager.IsSignedIn(User))
            {
                <form action="/Account/Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-soft" type="submit">Выйти</button>
                </form>
            }
            else
            {
                <a class="btn btn-soft" href="/Account/Login">Войти</a>
                <a class="btn btn-primary" href="/Account/Register">Регистрация</a>
            }
        </div>
    </header>

    <main class="container">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div><b>ReviMarket</b><span> beta-платформа</span></div>
        <nav>
            <a href="/Info/Privacy">Конфиденциальность</a>
            <a href="/Info/Rules">Правила</a>
            <a href="/Info/Help">Помощь</a>
            <a href="/Info/About">О проекте</a>
            <a href="/Info/Contacts">Контакты</a>
        </nav>
    </footer>

    <script src="~/js/register-business-toggle.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
