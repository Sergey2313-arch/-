@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ReviMarket</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/product-photos.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-panel.css" asp-append-version="true" />
</head>
<body>
    <div class="bg-grid"></div>
    <header class="topbar">
        <a class="brand" href="/">
            <span class="brand-icon">R</span>
            <span><b>ReviMarket</b><small>работа • товары • сделки</small></span>
        </a>
        <nav class="nav">
            <a href="/Catalog">Товары</a>
            <a href="/Orders">Работа</a>
            <a href="/Creators">Исполнители</a>
            @if (SignInManager.IsSignedIn(User))
            {
                <a href="/admin.html">Панель</a>
            }
        </nav>
        <div class="auth">
            @if (SignInManager.IsSignedIn(User))
            {
                <form action="/Account/Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-soft" type="submit">Выйти</button>
                </form>
            }
            else
            {
                <a class="btn btn-soft" href="/Account/Login">Войти</a>
                <a class="btn btn-primary" href="/Account/Register">Регистрация</a>
            }
        </div>
    </header>

    <main class="container">
        @RenderBody()
    </main>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
