@{
    ViewData["Title"] = "Панель";
    var currentUser = ViewBag.User as ApplicationUser;
    var isStaff = User.IsInRole(UserRoles.Admin) || User.IsInRole(UserRoles.Manager);
}

<div class="admin-shell">
    <aside class="admin-sidebar neon-card">
        <div class="admin-logo">
            <div class="admin-logo-mark">R</div>
            <div>
                <b>ReviMarket</b>
                <small>admin beta</small>
            </div>
        </div>

        <nav class="admin-menu">
            <a class="active" href="#dashboard">Dashboard</a>
            <a href="#support">Чат поддержки</a>
            <a href="#orders-review">Проверка заказов</a>
            <a href="#user-reports">Обращения пользователей</a>
            <a href="#order-reports">Обращения по заказам</a>
            <a href="#team">Команда и роли</a>
            <a href="/Catalog">Товары</a>
            <a href="/Orders">Работа</a>
        </nav>

        <div class="admin-note">
            <b>Backend panel</b><br />
            Панель подключена к ASP.NET. Следующий шаг — реальные таблицы обращений и поддержки.
        </div>
    </aside>

    <main class="admin-main">
        <section id="dashboard" class="admin-top">
            <div>
                <p class="eyebrow">moderation / support / security</p>
                <h1>Система администрации</h1>
                <p>Единая панель для поддержки, обращений, проверки заказов и управления площадкой.</p>
            </div>

            <div class="admin-badge">
                <b>@currentUser?.DisplayName</b>
                <span>@currentUser?.AccountType</span>
            </div>
        </section>

        <section class="admin-stats">
            <article class="admin-stat neon-card">
                <span>Пользователи</span>
                <h3>@ViewBag.AllProductsCount</h3>
                <p>активность площадки</p>
            </article>

            <article class="admin-stat neon-card">
                <span>Заказы</span>
                <h3>@ViewBag.AllOrdersCount</h3>
                <p>на проверке и в работе</p>
            </article>

            <article class="admin-stat neon-card">
                <span>Поддержка</span>
                <h3>@ViewBag.MessagesCount</h3>
                <p>сообщений</p>
            </article>

            <article class="admin-stat neon-card">
                <span>Обращения</span>
                <h3>0</h3>
                <p>пока демо-блок</p>
            </article>
        </section>

        <section id="support" class="admin-section neon-card">
            <div class="admin-section-head">
                <div>
                    <p class="eyebrow">support chat</p>
                    <h2>Чат с пользователями</h2>
                    <p>Агенты поддержки общаются с пользователями и помогают по заказам.</p>
                </div>
                <a class="btn btn-primary" href="/Inbox">Открыть чат</a>
            </div>

            <div class="admin-list">
                <article class="admin-row">
                    <div>
                        <h3>Демо-диалог поддержки</h3>
                        <p>Пользователь спрашивает про заказ или проблему с исполнителем.</p>
                        <div class="admin-tags">
                            <span class="admin-tag">support</span>
                            <span class="admin-tag">new</span>
                            <span class="admin-tag">agent</span>
                        </div>
                    </div>
                    <a class="btn btn-soft" href="/Inbox">Ответить</a>
                </article>
            </div>
        </section>

        <section id="orders-review" class="admin-section neon-card">
            <div class="admin-section-head">
                <div>
                    <p class="eyebrow">orders check</p>
                    <h2>Проверка заказов от заказчиков</h2>
                    <p>Перед публикацией заказ проверяется: описание, бюджет, категория и корректность.</p>
                </div>
                <a class="btn btn-primary" href="/AdminQueue">Открыть проверку</a>
            </div>

            <div class="admin-list">
                <article class="admin-row">
                    <div>
                        <h3>Заказ ожидает проверки</h3>
                        <p>Админ или модератор открывает заказ и принимает решение по публикации.</p>
                        <div class="admin-tags">
                            <span class="admin-tag">order</span>
                            <span class="admin-tag">pending</span>
                            <span class="admin-tag">customer</span>
                        </div>
                    </div>
                    <a class="btn btn-soft" href="/AdminQueue">Проверить</a>
                </article>
            </div>
        </section>

        <section id="user-reports" class="admin-section neon-card">
            <div class="admin-section-head">
                <div>
                    <p class="eyebrow">user reports</p>
                    <h2>Обращения на пользователей</h2>
                    <p>Проверка профилей, переписок и действий участников биржи.</p>
                </div>
                <a class="btn btn-soft" href="#team">Назначить агента</a>
            </div>

            <div class="admin-list">
                <article class="admin-row">
                    <div>
                        <h3>Демо-обращение на пользователя</h3>
                        <p>Здесь будет: кто отправил обращение, на кого, причина и решение агента.</p>
                        <div class="admin-tags">
                            <span class="admin-tag">user</span>
                            <span class="admin-tag">report</span>
                            <span class="admin-tag">review</span>
                        </div>
                    </div>
                    <button class="btn btn-soft" type="button">Открыть</button>
                </article>
            </div>
        </section>

        <section id="order-reports" class="admin-section neon-card">
            <div class="admin-section-head">
                <div>
                    <p class="eyebrow">order reports</p>
                    <h2>Обращения по заказам</h2>
                    <p>Проблемные заказы: сроки, результат работы и решение администрации.</p>
                </div>
                <a class="btn btn-soft" href="/AdminQueue">Проверить заказ</a>
            </div>

            <div class="admin-list">
                <article class="admin-row">
                    <div>
                        <h3>Демо-обращение по заказу</h3>
                        <p>Агент поддержки проверяет заказ, переписку и материалы по работе.</p>
                        <div class="admin-tags">
                            <span class="admin-tag">deal</span>
                            <span class="admin-tag">work</span>
                            <span class="admin-tag">decision</span>
                        </div>
                    </div>
                    <button class="btn btn-soft" type="button">Разобрать</button>
                </article>
            </div>
        </section>

        <section id="team" class="admin-section neon-card">
            <div class="admin-section-head">
                <div>
                    <p class="eyebrow">team roles</p>
                    <h2>Команда и роли</h2>
                    <p>Владельцы и совладельцы назначают агентов поддержки, модераторов и админов.</p>
                </div>
                <a class="btn btn-primary" href="/Team">Открыть команду</a>
            </div>

            <div class="admin-grid">
                <article class="admin-card">
                    <h3>Owner / владелец</h3>
                    <p>Главный доступ к управлению биржей.</p>
                </article>

                <article class="admin-card">
                    <h3>CoOwner / совладелец</h3>
                    <p>Помогает управлять командой и процессами.</p>
                </article>

                <article class="admin-card">
                    <h3>Support agent</h3>
                    <p>Отвечает пользователям и разбирает обращения.</p>
                </article>

                <article class="admin-card">
                    <h3>Moderator</h3>
                    <p>Проверяет заказы, товары и обращения.</p>
                </article>

                <article class="admin-card">
                    <h3>Admin</h3>
                    <p>Следит за площадкой и системными разделами.</p>
                </article>

                <article class="admin-card">
                    <h3>User</h3>
                    <p>Обычный заказчик или исполнитель.</p>
                </article>
            </div>
        </section>
    </main>
</div>
