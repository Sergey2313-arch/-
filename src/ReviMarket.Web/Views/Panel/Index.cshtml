@{
    ViewData["Title"] = "Панель";
    var currentUser = ViewBag.User as ApplicationUser;
    var accountType = currentUser?.AccountType ?? "User";
    var isAdmin = User.IsInRole(UserRoles.Admin) || accountType == UserRoles.Admin;
    var isManager = User.IsInRole(UserRoles.Manager) || accountType == UserRoles.Manager;
    var isOwner = accountType == "Owner" || accountType == "CoOwner" || isManager;
    var canSeeFinance = isOwner || isAdmin;
    var canSeeModeration = isOwner || isAdmin || accountType == "Moderator";
    var canSeeSupport = isOwner || isAdmin || accountType == "SupportAgent";
    var canSeeLegal = isOwner || isAdmin || accountType == "Lawyer";
    var canSeeTeam = isOwner || isAdmin;
}

<div class="admin-shell">
    <aside class="admin-sidebar neon-card">
        <div class="admin-logo">
            <div class="admin-logo-mark">R</div>
            <div><b>ReviMarket</b><small>@accountType</small></div>
        </div>

        <nav class="admin-menu">
            <a class="active" href="#dashboard">Dashboard</a>
            @if (canSeeFinance) { <a href="#finance">Финансы</a> }
            @if (canSeeModeration) { <a href="#orders-review">Проверка заказов</a> }
            @if (canSeeSupport) { <a href="#support">Поддержка</a> }
            @if (canSeeLegal) { <a href="#legal">Споры</a> }
            @if (canSeeTeam) { <a href="#team">Команда</a> }
            <a href="/Orders">Работа</a>
            <a href="/Profile">Профиль</a>
        </nav>

        <div class="admin-note">
            <b>Role based panel</b><br />
            Панель показывает только нужные разделы по роли аккаунта.
        </div>
    </aside>

    <main class="admin-main">
        <section id="dashboard" class="admin-top">
            <div>
                <p class="eyebrow">moderation / support / security</p>
                <h1>Система администрации</h1>
                <p>Единая панель для заказов, финансов, поддержки, споров и ролей.</p>
            </div>
            <div class="admin-badge"><b>@currentUser?.DisplayName</b><span>@accountType</span></div>
        </section>

        <section class="admin-stats">
            <article class="admin-stat neon-card"><span>Заказы</span><h3>@ViewBag.AllOrdersCount</h3><p>всего на бирже</p></article>
            <article class="admin-stat neon-card"><span>В работе</span><h3>@ViewBag.InWorkOrdersCount</h3><p>заказов с исполнителем</p></article>
            <article class="admin-stat neon-card"><span>Сделки</span><h3>@ViewBag.ActiveDealsCount</h3><p>активный холд</p></article>
            <article class="admin-stat neon-card"><span>Сообщения</span><h3>@ViewBag.MessagesCount</h3><p>мои диалоги</p></article>
        </section>

        @if (canSeeFinance)
        {
            <section id="finance" class="admin-section neon-card">
                <div class="admin-section-head">
                    <div><p class="eyebrow">finance</p><h2>Финансы и холд</h2><p>Проверка оборота, удержаний, комиссий, выводов и возвратов.</p></div>
                    <a class="btn btn-primary" href="/AdminFinance">Открыть финансы</a>
                </div>
            </section>
        }

        @if (canSeeModeration)
        {
            <section id="orders-review" class="admin-section neon-card">
                <div class="admin-section-head">
                    <div><p class="eyebrow">orders check</p><h2>Проверка заказов</h2><p>Модерация заказов перед публикацией в общей ленте.</p></div>
                    <a class="btn btn-primary" href="/AdminQueue">Открыть очередь</a>
                </div>
            </section>
        }

        @if (canSeeSupport)
        {
            <section id="support" class="admin-section neon-card">
                <div class="admin-section-head">
                    <div><p class="eyebrow">support</p><h2>Поддержка пользователей</h2><p>Помощь по заказам, оплате, холду, выводам и техническим вопросам.</p></div>
                    <a class="btn btn-primary" href="/Inbox">Открыть чат</a>
                </div>
            </section>
        }

        @if (canSeeLegal)
        {
            <section id="legal" class="admin-section neon-card">
                <div class="admin-section-head">
                    <div><p class="eyebrow">legal cases</p><h2>Спорные заказы</h2><p>Разбор конфликтов внутри биржи. Внешние контакты и обход ReviMarket запрещены.</p></div>
                    <a class="btn btn-soft" href="/AdminQueue">Проверить материалы</a>
                </div>
            </section>
        }

        @if (canSeeTeam)
        {
            <section id="team" class="admin-section neon-card">
                <div class="admin-section-head">
                    <div><p class="eyebrow">team roles</p><h2>Команда и роли</h2><p>Назначение админов, модераторов, юристов и агентов поддержки.</p></div>
                    <a class="btn btn-primary" href="/Team">Открыть команду</a>
                </div>
            </section>
        }
    </main>
</div>
