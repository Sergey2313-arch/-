@model RegisterViewModel
@{
    ViewData["Title"] = "Регистрация";
}

<section class="auth-card neon-card">
    <p class="eyebrow">create account</p>
    <h1>Регистрация ReviMarket</h1>
    <p>Выбери роль на бирже и тип аккаунта: физическое лицо или бизнес-аккаунт.</p>

    <form asp-action="Register" method="post" class="form">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="validation"></div>

        <div class="role-choice">
            <label class="role-card">
                <input asp-for="AccountType" type="radio" value="Customer" checked />
                <span>
                    <b>Заказчик</b>
                    <small>Создаёт заказы, выбирает исполнителя, ведёт сделку.</small>
                </span>
            </label>

            <label class="role-card">
                <input asp-for="AccountType" type="radio" value="Creator" />
                <span>
                    <b>Исполнитель</b>
                    <small>Добавляет услуги/товары, откликается на заказы, общается с заказчиком.</small>
                </span>
            </label>
        </div>

        <label>Тип лица</label>
        <div class="role-choice">
            <label class="role-card">
                <input asp-for="LegalType" type="radio" value="Individual" checked />
                <span>
                    <b>Физ. лицо</b>
                    <small>Обычный пользователь платформы.</small>
                </span>
            </label>

            <label class="role-card">
                <input asp-for="LegalType" type="radio" value="Business" />
                <span>
                    <b>ИП / юр. лицо</b>
                    <small>Для компаний, предпринимателей и бизнес-заказчиков.</small>
                </span>
            </label>
        </div>

        <label>Имя / ник</label>
        <input asp-for="DisplayName" placeholder="Например ReviveCode" />
        <span asp-validation-for="DisplayName" class="validation"></span>

        <label>Email</label>
        <input asp-for="Email" placeholder="mail@example.com" />
        <span asp-validation-for="Email" class="validation"></span>

        <label>Название ИП / организации</label>
        <input asp-for="OrganizationName" placeholder="Например ИП Коробков С. А. или ООО РевиМаркет" />

        <label>ИНН</label>
        <input asp-for="Inn" placeholder="ИНН для бизнес-аккаунта" />

        <label>ОГРН / ОГРНИП</label>
        <input asp-for="OgrnOrOgrnip" placeholder="Можно заполнить позже" />

        <label>Юридический адрес</label>
        <input asp-for="LegalAddress" placeholder="Можно заполнить позже" />

        <label>Пароль</label>
        <input asp-for="Password" placeholder="Минимум 6 символов" />
        <span asp-validation-for="Password" class="validation"></span>

        <div class="admin-note">
            <b>Зачем это нужно?</b>
            <span>Тип лица пригодится для платежей, договоров, чеков, безопасных сделок и выплат.</span>
        </div>

        <button class="btn btn-primary" type="submit">Зарегистрироваться</button>
    </form>
</section>
