@model List<ApplicationUser>
@{
    ViewData["Title"] = "Исполнители";
    var onlineLimit = ViewBag.OnlineLimit as DateTime? ?? DateTime.UtcNow.AddMinutes(-5);
}

<section class="section-head">
    <div>
        <p class="eyebrow">creators</p>
        <h1>Исполнители</h1>
        <p>Рейтинг, отзывы и статус активности исполнителей ReviMarket.</p>
    </div>
</section>

<div class="grid">
@foreach (var user in Model)
{
    var online = user.LastSeenAt is not null && user.LastSeenAt > onlineLimit;
    <article class="card">
        <div class="card-top"><span class="tag">@(online ? "В сети" : "Не в сети")</span><span class="price">★ @user.Rating.ToString("0.00")</span></div>
        <h3>@user.DisplayName</h3>
        <p>@user.ReviewsCount отзывов • на платформе с @user.CreatedAt.ToString("dd.MM.yyyy")</p>
        <div class="card-bottom"><a class="btn btn-soft" asp-controller="Profile" asp-action="Public" asp-route-id="@user.Id">Профиль</a><a class="btn btn-primary" asp-controller="Orders" asp-action="Index">Найти заказ</a></div>
    </article>
}
</div>
