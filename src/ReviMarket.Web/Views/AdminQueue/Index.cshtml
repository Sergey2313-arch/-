@model List<MarketItem>
@{
    ViewData["Title"] = "Проверка публикаций";
}

<section class="section-head">
    <div>
        <p class="eyebrow">admin queue</p>
        <h1>Проверка публикаций</h1>
        <p>Товары, вакансии и заказы, которые нужно проверить перед публикацией.</p>
    </div>
    <a class="btn btn-soft" href="/admin.html">← В панель</a>
</section>

<div class="review-list">
@foreach (var item in Model)
{
    <article class="review-row neon-card">
        <div>
            <div class="review-title">
                <b>@item.Title</b>
                <span class="tag">@item.ReviewStatus</span>
                <span class="tag">@DisplayType(item.Type)</span>
            </div>
            <p>@item.Description</p>
            <div class="review-meta">
                <span>@item.Category</span>
                <span>@item.Price.ToString("N0") ₽</span>
                <span>@(item.Owner?.DisplayName ?? "ReviMarket")</span>
            </div>
        </div>
        <div class="review-actions">
            @if (item.Type == MarketItemTypes.Product)
            {
                <a class="btn btn-soft" asp-controller="Catalog" asp-action="Details" asp-route-id="@item.Id">Открыть</a>
            }
            else if (item.Type == MarketItemTypes.Order)
            {
                <a class="btn btn-soft" asp-controller="Orders" asp-action="Details" asp-route-id="@item.Id">Открыть</a>
            }
            else
            {
                <a class="btn btn-soft" href="/Board">Открыть</a>
            }

            <form asp-action="Approve" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@item.Id" />
                <button class="btn btn-primary" type="submit">Одобрить</button>
            </form>

            <form asp-action="ReturnToQueue" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@item.Id" />
                <button class="btn btn-soft" type="submit">На проверку</button>
            </form>

            <form asp-action="Block" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@item.Id" />
                <button class="btn btn-soft" type="submit">Скрыть</button>
            </form>
        </div>
    </article>
}
</div>

@if (!Model.Any())
{
    <section class="empty neon-card">
        <h2>Публикаций пока нет</h2>
        <p>Когда пользователи начнут добавлять товары, вакансии и заказы, они появятся здесь.</p>
    </section>
}

@functions {
    string DisplayType(string type) => type switch
    {
        MarketItemTypes.Product => "Товар",
        MarketItemTypes.Order => "Работа",
        MarketItemTypes.Vacancy => "Вакансия",
        _ => "Публикация"
    };
}
