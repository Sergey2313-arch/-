@model List<MarketItem>
@{
    ViewData["Title"] = "Товары";
    var categories = ViewBag.Categories as string[] ?? Array.Empty<string>();
    var activeCategory = ViewBag.Category as string;
}

<section class="section-head">
    <div>
        <p class="eyebrow">products</p>
        <h1>Товары и услуги</h1>
        <p>Информационные товары, шаблоны, цифровые услуги, аудиты, макеты и готовые предложения.</p>
    </div>
    @if (User.IsInRole(UserRoles.Creator) || User.IsInRole(UserRoles.Admin))
    {
        <a class="btn btn-primary" asp-action="Create">+ Товар / услуга</a>
    }
</section>

<form method="get" class="toolbar neon-card product-filter">
    <input name="search" value="@ViewBag.Search" placeholder="Поиск товара или услуги..." />
    <select name="category">
        @if (string.IsNullOrWhiteSpace(activeCategory))
        {
            <option value="" selected>Все категории</option>
        }
        else
        {
            <option value="">Все категории</option>
        }
        @foreach (var category in categories)
        {
            if (activeCategory == category)
            {
                <option value="@category" selected>@category</option>
            }
            else
            {
                <option value="@category">@category</option>
            }
        }
    </select>
    <button class="btn btn-soft" type="submit">Найти</button>
</form>

<div class="grid product-grid">
@foreach (var item in Model)
{
    <article class="card product-card">
        @if (!string.IsNullOrWhiteSpace(item.ImagePath))
        {
            <div class="product-cover product-cover-photo" style="background-image: linear-gradient(rgba(7,3,15,.12), rgba(7,3,15,.72)), url('@item.ImagePath')">
                <div class="product-cover-title">
                    <b>@item.Title</b>
                    <span>@item.Category</span>
                </div>
            </div>
        }
        else
        {
            <div class="product-cover">
                <div class="product-cover-icon">@CategoryIcon(item.Category)</div>
                <div class="product-cover-title">
                    <b>@item.Title</b>
                    <span>@item.Category</span>
                </div>
            </div>
        }
        <div class="product-body">
            <div class="card-top"><span class="tag">@item.Category</span><span class="price">@item.Price.ToString("N0") ₽</span></div>
            <h3>@item.Title</h3>
            <p>@item.Description</p>
            <div class="card-bottom"><span>@(item.Owner?.DisplayName ?? "ReviMarket")</span><a class="btn btn-soft" asp-action="Details" asp-route-id="@item.Id">Подробнее</a></div>
        </div>
    </article>
}
</div>

@if (!Model.Any())
{
    <section class="empty neon-card">
        <h2>Пока ничего нет</h2>
        <p>Попробуй выбрать другую категорию или убрать поиск.</p>
    </section>
}

@functions {
    string CategoryIcon(string category) => category switch
    {
        MarketCategories.Design => "🎨",
        MarketCategories.It => "💻",
        MarketCategories.Ai => "🤖",
        MarketCategories.Content => "✍️",
        MarketCategories.Seo => "📈",
        MarketCategories.Marketplaces => "🛒",
        _ => "🧩"
    };
}
