@model MarketItem
@{
    ViewData["Title"] = "Добавить товар";
    var categories = ViewBag.Categories as string[] ?? MarketCategories.All;
}

<section class="auth-card neon-card">
    <p class="eyebrow">new product</p>
    <h1>Добавить товар / услугу</h1>
    <p>Загрузи обложку товара, чтобы карточка выглядела как нормальная витрина.</p>

    <form asp-action="Create" method="post" enctype="multipart/form-data" class="form">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="validation"></div>

        <label>Название</label>
        <input asp-for="Title" />

        <label>Описание</label>
        <textarea asp-for="Description"></textarea>

        <label>Цена</label>
        <input asp-for="Price" type="number" min="0" step="100" />

        <label>Блок / категория</label>
        <select asp-for="Category">
            @foreach (var category in categories)
            {
                <option value="@category">@category</option>
            }
        </select>

        <label>Фото товара</label>
        <input name="imageFile" type="file" accept="image/png,image/jpeg,image/webp" />
        <small class="form-hint">JPG, PNG или WEBP до 5 МБ.</small>

        <button class="btn btn-primary" type="submit">Опубликовать</button>
    </form>
</section>
