@model List<MarketItem>
@{
    ViewData["Title"] = "Работа";
    var categories = ViewBag.Categories as string[] ?? Array.Empty<string>();
    var activeCategory = ViewBag.Category as string;
}

<section class="section-head">
    <div>
        <p class="eyebrow">work board</p>
        <h1>Работа</h1>
        <p>Заказчики публикуют задачи, исполнители берут их в работу.</p>
    </div>
    @if (User.IsInRole(UserRoles.Customer) || User.IsInRole(UserRoles.Admin))
    {
        <a class="btn btn-primary" asp-action="Create">+ Создать заказ</a>
    }
</section>

<nav class="category-blocks neon-card">
    <a class="category-block @(string.IsNullOrWhiteSpace(activeCategory) ? "active" : "")" asp-action="Index" asp-route-search="@ViewBag.Search">
        <span>🧩</span><b>Все</b><small>Все заказы</small>
    </a>
    @foreach (var category in categories)
    {
        <a class="category-block @(activeCategory == category ? "active" : "")" asp-action="Index" asp-route-category="@category" asp-route-search="@ViewBag.Search">
            <span>@CategoryIcon(category)</span><b>@category</b><small>@CategoryDescription(category)</small>
        </a>
    }
</nav>

<form method="get" class="toolbar neon-card">
    <input type="hidden" name="category" value="@activeCategory" />
    <input name="search" value="@ViewBag.Search" placeholder="Поиск заказа..." />
    <button class="btn btn-soft" type="submit">Найти</button>
</form>

<div class="grid">
@foreach (var item in Model)
{
    <article class="card">
        <div class="card-top"><span class="tag">@item.Category</span><span class="price">@item.Price.ToString("N0") ₽</span></div>
        <h3>@item.Title</h3>
        <p>@item.Description</p>
        <div class="review-meta">
            <span>@(item.Owner?.DisplayName ?? "Заказчик")</span>
            <span>@DisplayOrderStatus(item)</span>
        </div>
        <div class="card-bottom"><a class="btn btn-soft" asp-action="Details" asp-route-id="@item.Id">Открыть заказ</a></div>
    </article>
}
</div>

@if (!Model.Any())
{
    <section class="empty neon-card">
        <h2>Пока заказов нет</h2>
        <p>Заказчик может создать первый заказ, после проверки он появится в общей ленте.</p>
    </section>
}

@functions {
    string DisplayOrderStatus(MarketItem item) => item.OrderStatus switch
    {
        OrderStatuses.Open => "Открыт",
        OrderStatuses.InWork => $"В работе: {item.AssignedExecutor?.DisplayName ?? "исполнитель"}",
        OrderStatuses.Done => "Завершён",
        _ => item.OrderStatus
    };

    string CategoryIcon(string category) => category switch
    {
        MarketCategories.Design => "🎨",
        MarketCategories.It => "💻",
        MarketCategories.Ai => "🤖",
        MarketCategories.Content => "✍️",
        MarketCategories.Seo => "📈",
        MarketCategories.Marketplaces => "🛒",
        _ => "🧩"
    };

    string CategoryDescription(string category) => category switch
    {
        MarketCategories.Design => "карточки, баннеры, визуал",
        MarketCategories.It => "сайты, боты, backend",
        MarketCategories.Ai => "промпты, генерация, AI",
        MarketCategories.Content => "тексты, описания, посты",
        MarketCategories.Seo => "аудит, ключи, трафик",
        MarketCategories.Marketplaces => "WB, Ozon, инфографика",
        _ => "категория"
    };
}
