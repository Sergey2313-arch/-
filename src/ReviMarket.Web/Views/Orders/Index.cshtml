@model List<MarketItem>
@{
    ViewData["Title"] = "Заказы";
}

<section class="section-head">
    <div>
        <p class="eyebrow">order board</p>
        <h1>Биржа заказов</h1>
        <p>Задачи, которые нужно выполнить: дизайн, сайты, карточки, тексты и IT.</p>
    </div>
    @if (User.IsInRole(UserRoles.Customer) || User.IsInRole(UserRoles.Admin))
    {
        <a class="btn btn-primary" asp-action="Create">+ Заказ</a>
    }
</section>

<form method="get" class="toolbar neon-card">
    <input name="search" value="@ViewBag.Search" placeholder="Поиск заказа..." />
    <button class="btn btn-soft" type="submit">Найти</button>
</form>

<div class="grid">
@foreach (var item in Model)
{
    <article class="card">
        <div class="card-top"><span class="tag">@item.Category</span><span class="price">@item.Price.ToString("N0") ₽</span></div>
        <h3>@item.Title</h3>
        <p>@item.Description</p>
        <div class="card-bottom"><span>@(item.Owner?.DisplayName ?? "Заказчик")</span><a class="btn btn-soft" asp-action="Details" asp-route-id="@item.Id">Подробности</a></div>
    </article>
}
</div>
