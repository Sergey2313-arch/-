@model MarketItem
@{
    ViewData["Title"] = Model.Title;
    var deal = ViewBag.Deal as Deal;
    var isOwner = User.Identity?.Name == Model.Owner?.Email;
    var isExecutor = User.Identity?.Name == Model.AssignedExecutor?.Email;
    var onlineLimit = DateTime.UtcNow.AddMinutes(-5);
    var ownerOnline = Model.Owner?.LastSeenAt is not null && Model.Owner.LastSeenAt > onlineLimit;
    var executorOnline = Model.AssignedExecutor?.LastSeenAt is not null && Model.AssignedExecutor.LastSeenAt > onlineLimit;
}

<section class="detail-page">
    <a class="btn btn-soft detail-back" asp-action="Index">← Назад к заказам</a>

    <div class="detail-layout neon-card">
        <article class="detail-main">
            <p class="eyebrow">order detail</p>
            <h1>@Model.Title</h1>
            <p class="detail-lead">@Model.Description</p>

            <div class="detail-block">
                <h2>Как работает заказ</h2>
                <p>Заказчик публикует заказ, исполнитель берёт его в работу, затем заказчик оплачивает заказ через холд ReviMarket.</p>
            </div>

            <div class="detail-block">
                <h2>Правило биржи</h2>
                <p>Контакты вне ReviMarket запрещены. Все договорённости, оплата, спор и переписка должны идти внутри платформы.</p>
            </div>
        </article>

        <aside class="detail-sidebar">
            <div class="detail-price-box">
                <span>Бюджет заказа</span>
                <b>@Model.Price.ToString("N0") ₽</b>
            </div>

            <div class="detail-info-list">
                <div><span>Категория</span><b>@Model.Category</b></div>
                <div><span>Заказчик</span><b><a asp-controller="Profile" asp-action="Public" asp-route-id="@Model.OwnerId">@(Model.Owner?.DisplayName ?? "Заказчик")</a></b></div>
                <div><span>Рейтинг заказчика</span><b>★ @((Model.Owner?.Rating ?? 0).ToString("0.00")) • @(ownerOnline ? "в сети" : "не в сети")</b></div>
                <div><span>Исполнитель</span><b>@if (Model.AssignedExecutor is not null) { <a asp-controller="Profile" asp-action="Public" asp-route-id="@Model.AssignedExecutorId">@Model.AssignedExecutor.DisplayName</a> } else { <span>не назначен</span> }</b></div>
                @if (Model.AssignedExecutor is not null)
                {
                    <div><span>Рейтинг исполнителя</span><b>★ @Model.AssignedExecutor.Rating.ToString("0.00") • @(executorOnline ? "в сети" : "не в сети")</b></div>
                }
                <div><span>Статус</span><b>@DisplayStatus(Model, deal)</b></div>
            </div>

            @if (Model.OrderStatus == OrderStatuses.Open && User.IsInRole(UserRoles.Creator) && !isOwner)
            {
                <form asp-action="Take" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button class="btn btn-primary detail-action" type="submit">Взять в работу</button>
                </form>
            }

            @if (Model.OrderStatus == OrderStatuses.InWork && isOwner && deal is null)
            {
                <form asp-action="Fund" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button class="btn btn-primary detail-action" type="submit">Оплатить в холд</button>
                </form>
            }

            @if (deal is not null)
            {
                <a class="btn btn-soft detail-action" asp-controller="Deals" asp-action="Index">Открыть сделку</a>
            }

            @if (Model.OrderStatus == OrderStatuses.InWork && (isOwner || isExecutor))
            {
                <a class="btn btn-soft detail-action" asp-controller="Inbox" asp-action="Index">Чат ReviMarket</a>
            }
        </aside>
    </div>
</section>

@functions {
    string DisplayStatus(MarketItem item, Deal? deal)
    {
        if (deal is not null) return $"Оплачен: {deal.Status}";
        return item.OrderStatus switch
        {
            OrderStatuses.Open => "Открыт",
            OrderStatuses.InWork => "В работе",
            OrderStatuses.Done => "Завершён",
            OrderStatuses.Cancelled => "Отменён",
            _ => item.OrderStatus
        };
    }
}
