@model MarketItem
@{
    ViewData["Title"] = Model.Title;
}

<section class="detail-page">
    <a class="btn btn-soft detail-back" asp-action="Index">← Назад к заказам</a>

    <div class="detail-layout neon-card">
        <article class="detail-main">
            <p class="eyebrow">order detail</p>
            <h1>@Model.Title</h1>
            <p class="detail-lead">@Model.Description</p>

            <div class="detail-block">
                <h2>Что нужно сделать</h2>
                <p>
                    Исполнителю нужно выполнить задачу по описанию заказчика. В полной версии здесь будут файлы ТЗ,
                    этапы работы, отклики исполнителей и статус безопасной сделки.
                </p>
            </div>
        </article>

        <aside class="detail-sidebar">
            <div class="detail-price-box">
                <span>Бюджет заказа</span>
                <b>@Model.Price.ToString("N0") ₽</b>
            </div>

            <div class="detail-info-list">
                <div><span>Категория</span><b>@Model.Category</b></div>
                <div><span>Заказчик</span><b>@(Model.Owner?.DisplayName ?? "Заказчик")</b></div>
                <div><span>Статус</span><b>Открыт</b></div>
                <div><span>Тип</span><b>Заказ</b></div>
            </div>

            <a class="btn btn-primary detail-action" asp-controller="Inbox" asp-action="Index">Откликнуться</a>
            <a class="btn btn-soft detail-action" asp-controller="Inbox" asp-action="Index">Написать заказчику</a>
        </aside>
    </div>
</section>
