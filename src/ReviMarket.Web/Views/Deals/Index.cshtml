@model List<Deal>
@{
    ViewData["Title"] = "Мои сделки";
    var myReviews = ViewBag.MyReviews as List<UserReview> ?? new();
}

<section class="section-head">
    <div>
        <p class="eyebrow">deals</p>
        <h1>Мои сделки</h1>
        <p>Сделки создаются автоматически после того, как исполнитель взял заказ, а заказчик оплатил его в холд.</p>
    </div>
    <a class="btn btn-primary" asp-controller="Orders" asp-action="Index">Перейти к заказам</a>
</section>

<div class="review-list">
@foreach (var deal in Model)
{
    var currentEmail = User.Identity?.Name;
    var isCustomer = currentEmail == deal.Customer?.Email;
    var isExecutor = currentEmail == deal.Executor?.Email;
    var reviewTargetId = isCustomer ? deal.ExecutorId : deal.CustomerId;
    var canReview = deal.Status == DealStatuses.Completed && !myReviews.Any(x => x.DealId == deal.Id && x.TargetUserId == reviewTargetId);

    <article class="review-row neon-card">
        <div>
            <div class="review-title">
                <b>Сделка #@deal.Id</b>
                <span class="tag">@deal.Status</span>
            </div>
            <p>@(deal.MarketItem?.Title ?? "Заказ")</p>
            <div class="review-meta">
                <span>Сумма: @deal.Amount.ToString("N0") ₽</span>
                <span>Комиссия: @deal.CommissionAmount.ToString("N0") ₽</span>
                <span>Исполнителю: @deal.ExecutorAmount.ToString("N0") ₽</span>
            </div>
            <div class="review-meta">
                <span>Заказчик: <a asp-controller="Profile" asp-action="Public" asp-route-id="@deal.CustomerId">@(deal.Customer?.DisplayName ?? "-")</a></span>
                <span>Исполнитель: <a asp-controller="Profile" asp-action="Public" asp-route-id="@deal.ExecutorId">@(deal.Executor?.DisplayName ?? "-")</a></span>
            </div>
        </div>
        <div class="review-actions">
            @if (deal.Status == DealStatuses.Funded && isCustomer)
            {
                <form asp-action="Complete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@deal.Id" />
                    <button class="btn btn-primary" type="submit">Завершить</button>
                </form>
            }

            @if (canReview)
            {
                <form asp-controller="Reviews" asp-action="Create" method="post" class="form compact-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="dealId" value="@deal.Id" />
                    <input type="hidden" name="targetUserId" value="@reviewTargetId" />
                    <select name="rating">
                        <option value="5">5 — отлично</option>
                        <option value="4">4 — хорошо</option>
                        <option value="3">3 — нормально</option>
                        <option value="2">2 — плохо</option>
                        <option value="1">1 — ужасно</option>
                    </select>
                    <textarea name="text" placeholder="Напиши отзыв" maxlength="600"></textarea>
                    <button class="btn btn-primary" type="submit">Оставить отзыв</button>
                </form>
            }
        </div>
    </article>
}
</div>

@if (!Model.Any())
{
    <section class="empty neon-card">
        <h2>Сделок пока нет</h2>
        <p>Создай заказ в разделе “Работа”, дождись исполнителя и оплати заказ в холд.</p>
    </section>
}
